# HisaabBot Webhook — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# WhatsApp webhook verification token (set same value in Meta/Gupshup dashboard)
WHATSAPP_VERIFY_TOKEN=hisaabbot_verify_2026

# HMAC-SHA256 app secret for payload signature verification (Meta Cloud API)
# Leave empty to skip signature verification during local development
WHATSAPP_APP_SECRET=
